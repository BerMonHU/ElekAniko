      "colorButton": "#ffffff",
      "colorLink": "#424a4d",
      "underlineLink": true,
      "opacity": "99",
      "text": "Kérünk, hogy az optimális felhasználói élmény érdekében fogadd el a sütiket.  <a href='privacy.html'>Infó itt</a>."
    },
    "gdpr": {
      "colorText": "#a7a7a7",
      "colorLink": "#149dcc",
      "underlineLink": false,
      "text": "Ide kattintva elfogadod a <a href='terms.html'>Felhasználási feltételeket</a> és <a href='policy.html'>Adatvédelmi szabályzatot</a>."
    },
    "cssOptimise": false,
    "lazyLoad": false,
    "favicon": "",
    "noImageResize": "",
    "google-analytics": "",
    "uniqCompNum": 73,
    "versionPublish": "4.10.15",
    "screenshot": "screenshot.png"
  },
  "pages": {
    "index.html": {
      "settings": {
        "main": true,
        "title": "www.elekaniko.hu",
